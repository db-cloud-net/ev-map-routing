# Copy to `.env` and fill in secrets. See TESTING.md for QA and optional tuning.
#
# Default manual testing: API :3001, Next.js :3000 — keep CORS in sync with the URL
# you open in the browser (e.g. http://localhost:3000).

PORT=3001
# Dev (DEPLOYMENT_ENV not production): before listen, best-effort kill stale listeners on PORT (ts-node-dev restarts).
# Set to "false" to disable (e.g. if something else legitimately shares the port).
# API_FREE_PORT_BEFORE_LISTEN=false
# Optional tuning if bind still races EADDRINUSE on Windows:
# API_LISTEN_MAX_ATTEMPTS=5
# API_AFTER_FREE_PORT_MS_WIN=220
# API_AFTER_FREE_PORT_MS_UNIX=60
# API_ALWAYS_SLEEP_AFTER_FREE=true   # wait after every free (slower cold start; use if needed)

CORS_ORIGIN=http://localhost:3000

# Deployment environment tag used for behavior toggles (e.g., CORS dev vs prod)
DEPLOYMENT_ENV=dev-local

# Required for charger lookup (NREL Station Locator API). This template never contains a real key.
# 1) Copy this file to `.env` in the same directory as `package.json` (repo root).
# 2) Sign up: https://developer.nrel.gov/signup/
# 3) Set the line below in `.env` to your key (not in `.env.example` — do not commit secrets).
NREL_API_KEY=
# Valhalla — see docs/VALHALLA.md. Port is usually 8002.
# Use localhost only if Valhalla runs on the same machine as this API. If Valhalla is on a NAS or another host, set e.g. http://192.168.1.50:8002 (must match what curl from this machine can reach).
VALHALLA_BASE_URL=http://192.168.86.38:8002

# Per-stage /plan budgets (see TESTING.md). Total cap: PLAN_TOTAL_TIMEOUT_MS on the API.
PLAN_TOTAL_TIMEOUT_MS=120000
PLAN_GEOCODE_TIMEOUT_MS=30000
PLAN_VALHALLA_POLYLINE_TIMEOUT_MS=60000
PLAN_VALHALLA_LEG_TIMEOUT_MS=30000

# Slice 4 — POST /route-preview (fast Valhalla preview; see docs/V2_API.md § Slice 4)
ROUTE_PREVIEW_TOTAL_TIMEOUT_MS=90000
ROUTE_PREVIEW_HORIZON_MINUTES=10
ROUTE_PREVIEW_MIN_MANEUVERS=2
NREL_FETCH_TIMEOUT_MS=60000
OVERPASS_FETCH_TIMEOUT_MS=60000

# Version 2 (waypoints + map candidates) — see docs/V2_API.md
V2_MAX_WAYPOINTS=8
# Max locked charger ids per driving leg (POST /plan lockedChargersByLeg rows)
V2_MAX_LOCKED_CHARGERS=8
# Set to "false" to skip Overpass hotel preview pins (chargers still returned when includeCandidates=true)
V2_HOTEL_MAP_PREVIEW=true

# Web (Next.js) — set in `web/.env.local` or env when running `npm -w web run dev` (see TESTING.md)
# Long multi-stop trips: raise API PLAN_TOTAL_TIMEOUT_MS first, then set client ≥ API + slack (only /plan is aborted).
# NEXT_PUBLIC_PLAN_CLIENT_TIMEOUT_MS=300000
# Merged /route-preview (teal + blue corridor) — abort so the UI does not wait forever (default 180s).
# NEXT_PUBLIC_ROUTE_PREVIEW_CLIENT_TIMEOUT_MS=300000
# NEXT_PUBLIC_PREFETCH_ROUTE_PREVIEW=true
