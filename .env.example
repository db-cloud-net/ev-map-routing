# Copy to `.env` and fill in secrets. See TESTING.md for QA and optional tuning.
#
# Default manual testing: API :3001, Next.js :3000 — keep CORS in sync with the URL
# you open in the browser (e.g. http://localhost:3000).

PORT=3001
# Smoke/E2E child processes set E2E_SPAWN_PORT + PORT so this value cannot override a spawned test port (see api/src/server.ts).
# Dev (DEPLOYMENT_ENV not production): before listen, best-effort kill stale listeners on PORT (ts-node-dev restarts).
# Set to "false" to disable (e.g. if something else legitimately shares the port).
# API_FREE_PORT_BEFORE_LISTEN=false
# Optional tuning if bind still races EADDRINUSE on Windows:
# API_LISTEN_MAX_ATTEMPTS=5
# API_AFTER_FREE_PORT_MS_WIN=220
# API_AFTER_FREE_PORT_MS_UNIX=60
# API_ALWAYS_SLEEP_AFTER_FREE=true   # wait after every free (slower cold start; use if needed)

CORS_ORIGIN=http://localhost:3000

# Deployment environment tag used for behavior toggles (e.g., CORS dev vs prod)
DEPLOYMENT_ENV=dev-local

# Corridor DCFC + hotels: POI Services (required for normal operation). Travel-Routing does not call live NREL/Overpass.
# POI_SERVICES_BASE_URL=http://localhost:8010
# On Docker (e.g. Synology NAS): same user-defined network as planner-api — e.g. POI_SERVICES_BASE_URL=http://poi:8010
# POI_SERVICES_TIMEOUT_MS=30000
# POI_SERVICES_API_KEY=
# USE_POI_SERVICES_CORRIDOR=true
# POI_SERVICES_USE_PAIRS=true
# POI_SERVICES_USE_EDGES=true
# Constrained Dijkstra on POI edge graph.
# USE_POI_CONSTRAINED_DIJKSTRA=false

# Corridor sampling (passed to POI Services as corridor_radius_mi). Prefer these names; legacy aliases still work.
# CORRIDOR_SEARCH_RADIUS_MILES=30
# Deprecated alias: NREL_RADIUS_MILES (same meaning)
# CORRIDOR_INCLUDE_ALL_ELECTRIC_CHARGERS=false
# Deprecated alias: NREL_INCLUDE_ALL_ELECTRIC_CHARGERS
# USE_CORRIDOR_NEARBY_ROUTE=false
# Deprecated alias: USE_NREL_NEARBY_ROUTE
# CORRIDOR_STEP_MILES=30
# CORRIDOR_MAX_SAMPLE_POINTS=80
# CANDIDATE_CHARGERS_CAP=25

# Optional — POI corridor sleep-stop review NDJSON (data QA for join coverage gaps):
# Enable with `POI_REVIEW_LOG=true`. Writes one JSON line per resolution attempt.
# POI_REVIEW_LOG=false
# POI_REVIEW_LOG_DIR=logs          # default: <cwd>/logs
# POI_REVIEW_LOG_FILE=poi-corridor-review.ndjson

# Valhalla — see docs/VALHALLA.md. Port is usually 8002.
# Use localhost only if Valhalla runs on the same machine as this API. If Valhalla is on a NAS or another host, set e.g. http://192.168.1.50:8002 (must match what curl from this machine can reach).
VALHALLA_BASE_URL=http://192.168.86.38:8002

# Per-stage /plan budgets (see TESTING.md).
# Segment solver budget (default 3 min). No total wall-clock cap for /plan.
PLAN_SEGMENT_TIMEOUT_MS=180000
PLAN_GEOCODE_TIMEOUT_MS=30000
PLAN_VALHALLA_POLYLINE_TIMEOUT_MS=60000
PLAN_VALHALLA_LEG_TIMEOUT_MS=30000

# Planner EV model (least-time segment + range-leg metrics). See docs/designs/range-leg-incremental-trust-adr.md
# EV_RANGE_MILES=260
# CHARGE_BUFFER_SOC=0
# Pillar 1 slice A: per rangeLeg max-hop chord vs usable range on POST /plan (default on; set false to shrink JSON)
# PLAN_RANGE_LEG_METRICS=true
# Linear SOC replay on successful plans → debug.socReplay (default on)
# PLAN_SOC_REPLAY=true
# Pillar 1 slice C: soft penalty (minutes) per charge stop in least-time Dijkstra — default 0 (off)
# PLAN_RANGE_LEG_CHARGE_STOP_PENALTY_MINUTES=0
# Pillar 1 slice D: tighten linear SOC distance caps (0–0.999); default 0 (off). See range-leg-incremental-trust-adr.md
# PLAN_RANGE_LEG_FEASIBILITY_MARGIN_FRAC=0
# Pillar 1 slice E: carry linear SOC across locked-charger segment chain (default on; false = full pack each segment)
# PLAN_SOC_CARRY_CHAINED_SEGMENTS=true
# Pillar 1 slice F: carry linear SOC into later overnight iterations + remainder in planTripOneLeg (default on)
# PLAN_SOC_CARRY_OVERNIGHT_SEGMENTS=true
# ROUTING_UX §4: planJob partial_route checkpoints after each timed segment hop (segment_refine_hop_*). Default on; set false to reduce checkpoint volume.
# PLAN_SEGMENT_PREFIX_REFINEMENT_CHECKPOINTS=true
# Multi-waypoint: time budget (ms) for haversine waypoint-order search before EV planning (optimizeWaypointOrder).
# PLAN_WAYPOINT_REORDER_BUDGET_MS=4000

# Slice 4 — POST /route-preview (fast Valhalla preview; see docs/V2_API.md § Slice 4)
# Same response can include a second time clip as preview.nextHorizon (same Valhalla call; ROUTING_UX_SPEC §5).
ROUTE_PREVIEW_TOTAL_TIMEOUT_MS=90000
ROUTE_PREVIEW_HORIZON_MINUTES=10
ROUTE_PREVIEW_MIN_MANEUVERS=2

# Async plan job streams (GET /plan/jobs/:id/stream, /events) — periodic JSON heartbeats keep long SSE/NDJSON connections alive through proxies.
# Default 25000 ms when unset; 0 or invalid values disable heartbeats.
# PLAN_JOB_SSE_HEARTBEAT_MS=25000

# Version 2 (waypoints + map candidates) — see docs/V2_API.md
V2_MAX_WAYPOINTS=12
# Optional: auto-waypoint splitting for long single-leg trips.
# Off by default; when enabled, planner injects internal waypoint coordinates for long routes.
# ENABLE_AUTO_WAYPOINTS=true
# AUTO_WAYPOINT_THRESHOLD_MI=500
# Max locked charger ids per driving leg (POST /plan lockedChargersByLeg rows)
V2_MAX_LOCKED_CHARGERS=8
# Set to "false" to skip hotel preview pins from POI corridor (chargers still returned when includeCandidates=true)
V2_HOTEL_MAP_PREVIEW=true

# Web (Next.js) — set in `web/.env.local` (build-time; see docs/WEB_SWITCHES.md — full switch table)
# NEXT_PUBLIC_API_BASE=http://localhost:3001
# Long multi-stop: in planJob mode this is an idle timeout that resets when new checkpoints arrive.
# Use a larger value if your environment emits checkpoints slowly.
# NEXT_PUBLIC_PLAN_CLIENT_TIMEOUT_MS=600000
# NEXT_PUBLIC_ROUTE_PREVIEW_CLIENT_TIMEOUT_MS=300000
# NEXT_PUBLIC_PREFETCH_CANDIDATES=true
# NEXT_PUBLIC_PREFETCH_ROUTE_PREVIEW=true
# NEXT_PUBLIC_PLAN_USE_JOB=true
# With planJob: use SSE GET /plan/jobs/:id/events (default). Set false to poll GET /plan/jobs/:id only.
# NEXT_PUBLIC_PLAN_USE_SSE=false
# Map marker defaults (build-time):
# - Dev default: candidates + auto-waypoint markers visible
# - Production default: hidden (unless you set true here)
# NEXT_PUBLIC_MAP_SHOW_CANDIDATES_DEFAULT=true
# NEXT_PUBLIC_MAP_SHOW_WAYPOINTS_DEFAULT=true
# Debug-only: rangeLeg polyline split + sidebar (not standard product)
# NEXT_PUBLIC_MAP_DEBUG_RANGE_LEGS=true
